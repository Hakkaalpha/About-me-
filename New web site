<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tushar Yadav | Portfolio</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap');

        :root {
            --bg-color: #09050e;
            --surface-color: rgba(255, 255, 255, 0.03);
            --primary-glow: #8a2be2;
            --secondary-glow: #4b0082;
            --text-main: #ffffff;
            --text-muted: #a0a0b0;
            --border-color: rgba(255, 255, 255, 0.08);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.6;
            position: relative;
        }

        /* Ambient Purple Glow Backgrounds */
        .glow-blob {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, var(--secondary-glow) 0%, rgba(9,5,14,0) 70%);
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
            opacity: 0.6;
            animation: pulseGlow 8s infinite alternate ease-in-out;
        }

        .glow-1 { top: -100px; left: -200px; }
        .glow-2 { top: 40%; right: -200px; background: radial-gradient(circle, var(--primary-glow) 0%, rgba(9,5,14,0) 70%); }
        .glow-3 { bottom: -100px; left: 20%; }

        @keyframes pulseGlow {
            0% { transform: scale(1); opacity: 0.5; }
            100% { transform: scale(1.2); opacity: 0.8; }
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: center;
            padding: 2rem;
            gap: 3rem;
            position: sticky;
            top: 0;
            background: rgba(9, 5, 14, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            z-index: 1000;
        }

        nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 1rem;
            font-weight: 400;
            transition: all 0.3s ease;
        }

        nav a:hover, nav a.active {
            color: var(--text-main);
            text-shadow: 0 0 10px var(--primary-glow);
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            position: relative;
            z-index: 1;
        }

        /* Hero Section */
        .hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 90vh;
            gap: 4rem;
        }

        .hero-left {
            flex: 1;
            animation: slideInLeft 1s ease-out forwards;
        }

        .greeting {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .greeting span {
            color: #b026ff;
            font-weight: 600;
        }

        .styled-quote {
            font-size: 1.5rem;
            font-weight: 300;
            line-height: 1.2;
            margin-bottom: 2rem;
            color: var(--text-muted);
        }

        .styled-quote strong {
            color: var(--text-main);
            font-size: 2.5rem;
            display: block;
        }

        .styled-quote .highlight {
            border: 1px solid var(--text-muted);
            border-radius: 50px;
            padding: 0 15px;
            display: inline-block;
        }

        .main-title {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 1rem;
            letter-spacing: -1px;
            display: flex;
            align-items: center;
        }

        .cursor {
            display: inline-block;
            width: 4px;
            height: 4rem;
            background-color: var(--text-main);
            margin-left: 10px;
            animation: blink 1s infinite;
        }

        .hero-desc {
            color: var(--text-muted);
            font-size: 1.1rem;
            max-width: 500px;
            margin-bottom: 2rem;
        }

        .hero-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        /* Avatar/Right Side */
        .hero-right {
            flex: 1;
            display: flex;
            justify-content: center;
            position: relative;
            animation: slideInRight 1s ease-out forwards;
        }

        .avatar-container {
            position: relative;
            width: 300px;
            height: 300px;
        }

        .avatar-container::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(138,43,226,0.4) 0%, transparent 70%);
            z-index: -1;
        }

        .avatar-img {
            width: 100%;
            border-radius: 20px;
            animation: float 6s ease-in-out infinite;
            filter: drop-shadow(0 0 20px rgba(138, 43, 226, 0.3));
        }

        /* Tools & Skills Grid */
        .section-title {
            font-size: 2.2rem;
            margin: 6rem 0 3rem;
            font-weight: 700;
            border-left: 4px solid var(--primary-glow);
            padding-left: 15px;
            position: relative;
        }

        .tools-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 2.5rem;
            margin-bottom: 4rem;
        }

        .tool-card {
            background: var(--surface-color);
            border: 1px solid var(--border-color);
            backdrop-filter: blur(10px);
            padding: 1.5rem 2rem;
            border-radius: 24px;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            flex: 1;
            min-width: 250px;
            opacity: 0;
            transform: translateY(20px);
        }

        .reveal.active .tool-card {
            opacity: 1;
            transform: translateY(0);
        }

        .tool-card:nth-child(1) { transition-delay: 0.1s; }
        .tool-card:nth-child(2) { transition-delay: 0.2s; }
        .tool-card:nth-child(3) { transition-delay: 0.3s; }
        .tool-card:nth-child(4) { transition-delay: 0.4s; }
        .tool-card:nth-child(5) { transition-delay: 0.5s; }
        .tool-card:nth-child(6) { transition-delay: 0.6s; }

        .tool-card:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: rgba(138, 43, 226, 0.6);
            box-shadow: 0 15px 35px rgba(138, 43, 226, 0.2);
        }

        .tool-card img {
            width: 45px;
            height: 45px;
            filter: drop-shadow(0 0 10px var(--primary-glow));
        }

        .tool-card span {
            font-weight: 600;
            font-size: 1.1rem;
            color: var(--text-main);
        }

        /* Achievements Cards */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2.5rem;
            margin-bottom: 5rem;
        }

        .achievement-card {
            background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
            border: 1px solid var(--border-color);
            border-radius: 28px;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
        }

        .achievement-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: linear-gradient(90deg, var(--primary-glow), var(--secondary-glow));
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .achievement-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.6);
            border-color: rgba(138, 43, 226, 0.3);
        }

        .achievement-card:hover::before {
            opacity: 1;
        }

        .achievement-card h3 {
            font-size: 1.6rem;
            margin-bottom: 1.2rem;
            color: #fff;
            font-weight: 700;
        }

        .achievement-card p {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 2rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            padding: 12px 28px;
            background: transparent;
            border: 1px solid var(--text-muted);
            color: var(--text-main);
            border-radius: 50px;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn:hover {
            background: var(--text-main);
            color: var(--bg-color);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
            transform: scale(1.05);
        }

        /* --- ANIMATIONS --- */
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        @keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-50px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(50px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

    </style>
</head>
